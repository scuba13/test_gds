# Root env example (used by docker compose and local dev)

# Postgres connection string (for local tooling). In docker compose, backend uses the container hostname `db`.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/app?schema=public

# JWT signing secret (dev only)
JWT_SECRET=dev-secret-change-me

# Allowed origin for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173
